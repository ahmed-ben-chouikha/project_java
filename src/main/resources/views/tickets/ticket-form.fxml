<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.tickets.TicketFormController" spacing="12" styleClass="page-root matches-page">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label fx:id="titleLabel" text="Create Ticket" styleClass="page-title" />

        <GridPane hgap="10" vgap="10" styleClass="card">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <children>
                <Label text="Game" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="gameCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="260"/>

                <Label text="Ticket Number" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="ticketNumberField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="TKT-2026-XXX"/>

                <Label text="Type" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="typeCombo" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="260"/>

                <Label text="Price" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="priceField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="25"/>

                <Label text="Quantity" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="quantityField" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="100"/>

                <Label text="Sold" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="soldField" GridPane.rowIndex="5" GridPane.columnIndex="1" promptText="0"/>

                <Label text="Status" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <ComboBox fx:id="statusCombo" GridPane.rowIndex="6" GridPane.columnIndex="1" prefWidth="260"/>

                <Label fx:id="feedbackLabel" text="" styleClass="muted" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            </children>
        </GridPane>

        <HBox spacing="8">
            <children>
                <Button text="Save" onAction="#onSave" styleClass="btn-primary"/>
                <Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/>
            </children>
        </HBox>
    </children>
</VBox>

