<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.tickets.TicketsController" spacing="12" styleClass="page-root matches-page">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Tickets" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search by ticket number, game, type" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="statusFilter" prefWidth="170" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Create Ticket" onAction="#onCreateTicket" styleClass="btn-primary" />
            </children>
        </HBox>

        <TableView fx:id="ticketsTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="gameIdCol" text="Game ID" prefWidth="90" />
                <TableColumn fx:id="ticketNumberCol" text="Ticket Number" prefWidth="200" />
                <TableColumn fx:id="typeCol" text="Type" prefWidth="100" />
                <TableColumn fx:id="priceCol" text="Price" prefWidth="90" />
                <TableColumn fx:id="quantityCol" text="Quantity" prefWidth="90" />
                <TableColumn fx:id="soldCol" text="Sold" prefWidth="90" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
            </columns>
        </TableView>

        <HBox spacing="8">
            <children>
                <Button text="Edit" onAction="#onEditTicket" styleClass="btn-secondary" />
                <Button text="Delete" onAction="#onDeleteTicket" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" />
            </children>
        </HBox>
    </children>
</VBox>

