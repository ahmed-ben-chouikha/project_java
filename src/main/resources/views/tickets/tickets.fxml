<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.tickets.TicketsController" spacing="16" styleClass="page-root tickets-page">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <HBox spacing="16" styleClass="card tickets-hero">
            <children>
                <VBox spacing="12" HBox.hgrow="ALWAYS" styleClass="tickets-hero-copy">
                    <children>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="dashboard-hero-topline">
                            <children>
                                <Label text="TICKET CONTROL" styleClass="top-nav-pill" />
                                <Label text="RankUp Operations" styleClass="muted dashboard-hero-kicker" />
                            </children>
                        </HBox>
                        <Label text="Tickets" styleClass="page-title" />
                        <Label text="Manage ticket inventory, pricing, and sales status from one sleek control panel." styleClass="muted dashboard-hero-subtitle" wrapText="true" />
                        <HBox spacing="8" styleClass="tickets-toolbar">
                            <children>
                                <TextField fx:id="searchField" promptText="Search by ticket number, game, type" HBox.hgrow="ALWAYS" styleClass="tickets-search" />
                                <ComboBox fx:id="statusFilter" prefWidth="170" styleClass="tickets-filter" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button text="Create Ticket" onAction="#onCreateTicket" styleClass="btn-primary tickets-create-btn" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="10" styleClass="card tickets-hero-summary">
                    <children>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <children>
                                <FontIcon iconLiteral="fas-ticket-alt" styleClass="tickets-summary-icon" />
                                <Label text="Stock view" styleClass="section-title" />
                            </children>
                        </HBox>
                        <Label text="Quick status chips and a clean table layout make inventory scanning easier." wrapText="true" styleClass="muted" />
                        <HBox spacing="8" styleClass="tickets-summary-chips">
                            <children>
                                <Label text="Available" styleClass="badge tickets-chip-live" />
                                <Label text="Sold out" styleClass="badge tickets-chip-open" />
                                <Label text="Cancelled" styleClass="badge tickets-chip-alert" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>

        <TableView fx:id="ticketsTable" VBox.vgrow="ALWAYS" styleClass="card tickets-table">
            <columns>
                <TableColumn fx:id="gameIdCol" text="Game ID" prefWidth="90" />
                <TableColumn fx:id="ticketNumberCol" text="Ticket Number" prefWidth="200" />
                <TableColumn fx:id="typeCol" text="Type" prefWidth="100" />
                <TableColumn fx:id="priceCol" text="Price" prefWidth="90" />
                <TableColumn fx:id="quantityCol" text="Quantity" prefWidth="90" />
                <TableColumn fx:id="soldCol" text="Sold" prefWidth="90" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
            </columns>
        </TableView>

        <HBox spacing="8" styleClass="tickets-footer">
            <children>
                <Button text="Edit" onAction="#onEditTicket" styleClass="btn-secondary action-btn-edit" />
                <Button text="Delete" onAction="#onDeleteTicket" styleClass="btn-danger action-btn-delete" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" styleClass="tickets-pagination" />
            </children>
        </HBox>
    </children>
</VBox>

