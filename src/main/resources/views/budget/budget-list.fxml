<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.BudgetController" style="-fx-background-color: linear-gradient(to bottom right, #070d1a, #0d1325 45%, #111827 100%);">
    <top>
        <VBox style="-fx-padding: 15px; -fx-spacing: 10px; -fx-background-color: transparent;">
            <HBox spacing="10">
                <Label text="Budget Management" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📤 Export CSV" onAction="#onExportBudgets" styleClass="btn-secondary"/>
                <Button text="➕ Ajouter Budget" onAction="#onAddBudget" style="-fx-padding: 8px 15px; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Rechercher..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="teamFilterCombo" promptText="Filtrer équipe" prefWidth="180"/>
                <ComboBox fx:id="sortCombo" promptText="Trier" prefWidth="220"/>
                <Button text="🔄 Rafraîchir" onAction="#onRefresh" style="-fx-padding: 5px 10px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="budgetTable" style="-fx-font-size: 11;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="teamNameColumn" text="Équipe" prefWidth="150"/>
                <TableColumn fx:id="montantAlloueColumn" text="Montant Alloué" prefWidth="120"/>
                <TableColumn fx:id="montantUtiliseColumn" text="Montant Utilisé" prefWidth="120"/>
                <TableColumn fx:id="restantColumn" text="Restant" prefWidth="100"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox style="-fx-padding: 10px; -fx-background-color: transparent;" spacing="10">
            <Label text="© 2026 Budget Management System" styleClass="muted"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Chargé" styleClass="muted"/>
        </HBox>
    </bottom>
</BorderPane>
