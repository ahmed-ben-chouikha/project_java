<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.teams.TeamsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Teams" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search by team or country" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="➕ New Team" onAction="#onCreateTeam" styleClass="btn-primary" />
            </children>
        </HBox>
        <TableView fx:id="teamsTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="nameCol" text="Team Name" prefWidth="190" />
                <TableColumn fx:id="countryCol" text="Country" prefWidth="160" />
                <TableColumn fx:id="gameCol" text="Game" prefWidth="160" />
                <TableColumn fx:id="scoreCol" text="Score" prefWidth="120" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button text="👁️" onAction="#onViewTeam" />
                <Button text="✏️" onAction="#onEditTeam" />
                <Button text="🗑️" onAction="#onDeleteTeam" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" />
            </children>
        </HBox>
    </children>
</VBox>

