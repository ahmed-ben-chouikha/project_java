<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.teams.TeamFormController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label fx:id="titleLabel" text="Create Team" styleClass="page-title" />
        <GridPane hgap="10" vgap="10" styleClass="card">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <children>
                <Label text="Team Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Required"/>

                <Label text="Country" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="countryField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Required"/>

                <Label text="Game" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <ComboBox fx:id="gameCombo" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="250"/>

                <Label text="Level" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <ComboBox fx:id="levelCombo" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="250"/>

                <Label text="Score" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="scoreField" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="0"/>

                <Label text="Short Description" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1" prefRowCount="2"/>

                <Label text="Detailed Description" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextArea fx:id="detailedDescriptionArea" GridPane.rowIndex="6" GridPane.columnIndex="1" prefRowCount="4"/>

                <Label text="Logo URL / Path" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <TextField fx:id="logoField" GridPane.rowIndex="7" GridPane.columnIndex="1" promptText="Optional"/>

                <Label fx:id="feedbackLabel" text="" styleClass="muted" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
        <HBox spacing="8"><children><Button text="Save" onAction="#onSave" styleClass="btn-primary"/><Button text="Cancel" onAction="#onCancel" styleClass="btn-secondary"/></children></HBox>
    </children>
</VBox>

