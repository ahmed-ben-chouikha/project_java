<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.SimpleActionsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Create / Edit Team" styleClass="page-title" />
        <GridPane hgap="10" vgap="10" styleClass="card">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <children>
                <Label text="Team Name" GridPane.rowIndex="0" GridPane.columnIndex="0"/><TextField GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Country" GridPane.rowIndex="1" GridPane.columnIndex="0"/><ComboBox GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="220"/>
                <Label text="Description" GridPane.rowIndex="2" GridPane.columnIndex="0"/><TextArea GridPane.rowIndex="2" GridPane.columnIndex="1" prefRowCount="3"/>
                <Label text="Budget" GridPane.rowIndex="3" GridPane.columnIndex="0"/><TextField GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Numeric"/>
                <Label text="Logo Upload" GridPane.rowIndex="4" GridPane.columnIndex="0"/><Button text="Choose File" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
        <HBox spacing="8"><children><Button text="💾 Save" onAction="#onSave" styleClass="btn-primary"/><Button text="✕ Cancel" onAction="#goBackTeams"/></children></HBox>
    </children>
</VBox>

