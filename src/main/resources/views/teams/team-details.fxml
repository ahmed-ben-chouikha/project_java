<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.SimpleActionsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Team Details - Falcons" styleClass="page-title" />
        <VBox spacing="6" styleClass="card"><padding><Insets top="12" right="12" bottom="12" left="12"/></padding><children>
            <Label text="Country: France"/>
            <Label text="Description: Competitive FPS roster"/>
            <Label text="Created Date: 2025-09-10"/>
            <Label text="Budget: Total $12,000 | Spent $7,500 | Remaining $4,500"/>
        </children></VBox>
        <Label text="Team Roster" styleClass="section-title" />
        <TableView VBox.vgrow="ALWAYS" styleClass="card"><columns>
            <TableColumn text="Player Name" prefWidth="180" />
            <TableColumn text="Nickname" prefWidth="140" />
            <TableColumn text="Role" prefWidth="120" />
            <TableColumn text="Stats" prefWidth="220" />
        </columns></TableView>
        <HBox spacing="8"><children>
            <Button text="✏️ Edit" onAction="#onEdit" styleClass="btn-primary" />
            <Button text="👤 Invite Player" onAction="#onInvite" styleClass="btn-primary" />
            <Button text="← Back" onAction="#goBackTeams" />
        </children></HBox>
    </children>
</VBox>

