<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.admin.AdminRegistrationController" spacing="18" styleClass="page-root">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>
    <children>
        <!-- Title -->
        <Label text="Tournament Registration Management" styleClass="page-title" />

        <!-- Info Panel -->
        <VBox styleClass="card" spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12" />
            </padding>
            <children>
                <Label fx:id="pendingCountLabel" text="Pending Registrations: 0" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #00BCD4;" />
                <Label fx:id="infoLabel" text="Loading..." style="-fx-font-size: 12; -fx-text-fill: #cbd5e1;" />
            </children>
        </VBox>

        <!-- Filter Panel -->
        <VBox styleClass="card" spacing="12">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14" />
            </padding>
            <children>
                <Label text="Filter Registrations" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #00BCD4;" />

                <!-- Tournament Filter -->
                <VBox spacing="4">
                    <Label text="Tournament" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <ComboBox fx:id="tournamentFilter" promptText="All Tournaments" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10;" />
                    <Label text="Select a tournament to view only registrations for that event" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Status Filter -->
                <VBox spacing="4">
                    <Label text="Status" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <ComboBox fx:id="statusFilter" promptText="All Statuses" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10;" />
                    <Label text="Filter by registration status: Pending (needs action), Confirmed, or Rejected" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Search Field -->
                <VBox spacing="4">
                    <Label text="Search" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="searchField" promptText="Search by player or team name" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10; -fx-font-size: 12;" />
                    <Label text="Type to find specific players or teams instantly" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>
            </children>
        </VBox>

        <!-- Registrations Table -->
        <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14" />
            </padding>
            <children>
                <TableView fx:id="registrationsTable" VBox.vgrow="ALWAYS" prefHeight="300" styleClass="card">
                    <columns>
                        <TableColumn fx:id="playerCol" text="Player Name" prefWidth="150" />
                        <TableColumn fx:id="teamCol" text="Team Name" prefWidth="150" />
                        <TableColumn fx:id="tournamentCol" text="Tournament" prefWidth="150" />
                        <TableColumn fx:id="dateCol" text="Registration Date" prefWidth="140" />
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
                    </columns>
                </TableView>

                <!-- Error/Success Message -->
                <Label fx:id="actionErrorLabel" text="" wrapText="true" style="-fx-font-size: 11; -fx-padding: 8; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-radius: 4; -fx-background-radius: 4;" />

                <!-- Action Buttons -->
                <HBox spacing="10">
                    <Button fx:id="acceptButton" text="✓ Accept Registration" style="-fx-background-color: #10b981; -fx-text-fill: #ffffff; -fx-padding: 10 20 10 20; -fx-font-size: 12; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-radius: 6;" onAction="#onAccept" />
                    <Button fx:id="rejectButton" text="✕ Reject Registration" styleClass="btn-danger" style="-fx-padding: 10 20 10 20;" onAction="#onReject" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Help Text -->
                <Label text="ℹ Select a pending registration and click Accept or Reject. When max teams is reached, the tournament will auto-close." style="-fx-text-fill: #94a3b8; -fx-font-size: 10; -fx-padding: 8; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-radius: 4; -fx-background-radius: 4;" wrapText="true" />

                <!-- Status Legend -->
                <HBox spacing="20" style="-fx-padding: 12; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-radius: 6;">
                    <Label text="Legend:" style="-fx-text-fill: #00BCD4; -fx-font-weight: bold; -fx-font-size: 11;" />
                    <Label text="🟡 Pending - Awaiting your action" style="-fx-text-fill: #fbbf24; -fx-font-size: 10;" />
                    <Label text="🟢 Confirmed - You accepted this" style="-fx-text-fill: #10b981; -fx-font-size: 10;" />
                    <Label text="🔴 Rejected - You rejected this" style="-fx-text-fill: #ef4444; -fx-font-size: 10;" />
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
