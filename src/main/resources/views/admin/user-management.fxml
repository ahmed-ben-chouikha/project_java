<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.admin.UserManagementController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Admin - User Management" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search by email or username" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="roleFilter" prefWidth="150" />
            </children>
        </HBox>
        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="idCol" text="User ID" prefWidth="80" />
                <TableColumn fx:id="emailCol" text="Email" prefWidth="230" />
                <TableColumn fx:id="usernameCol" text="Username" prefWidth="150" />
                <TableColumn fx:id="roleCol" text="Role" prefWidth="110" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="110" />
            </columns>
        </TableView>
        <HBox spacing="8"><children>
            <Button text="Ban User" onAction="#onBanUser" styleClass="btn-danger" />
            <Button text="Unban User" onAction="#onUnbanUser" />
            <Button text="Delete User" onAction="#onDeleteUser" styleClass="btn-danger" />
            <Button text="Edit Role" onAction="#onEditRole" />
            <Region HBox.hgrow="ALWAYS" />
        </children></HBox>
    </children>
</VBox>


