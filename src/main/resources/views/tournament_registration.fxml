<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.TournamentRegistrationUserController" spacing="20" styleClass="page-root">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>
    <children>
        <!-- Title -->
        <Label text="Tournament Registration" styleClass="page-title" />

        <!-- Registration Form Section -->
        <VBox styleClass="card" spacing="16">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14" />
            </padding>
            <children>
                <Label text="Register for a Tournament" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #00BCD4;" />

                <!-- Player Name Field -->
                <VBox spacing="4">
                    <Label text="Player Name" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="playerNameField" promptText="Enter your full name" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10; -fx-font-size: 12;" />
                    <Label text="This is required - enter your real player name" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Team Name Field -->
                <VBox spacing="4">
                    <Label text="Team Name" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="teamNameField" promptText="Enter team name" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10; -fx-font-size: 12;" />
                    <Label text="Minimum 3 characters - example: 'Dragon Squad' or 'Elite Team'" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Tournament Selection Field -->
                <VBox spacing="4">
                    <Label text="Select Tournament" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <ComboBox fx:id="tournamentComboBox" promptText="Choose a tournament" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10;" />
                    <Label text="Only open tournaments are available - pick one to register" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Error Message -->
                <Label fx:id="formErrorLabel" text="" wrapText="true" style="-fx-text-fill: #ef4444; -fx-font-size: 11; -fx-padding: 8; -fx-background-color: rgba(239, 68, 68, 0.1); -fx-border-color: #ef4444; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <!-- Success Message -->
                <Label fx:id="successLabel" text="" wrapText="true" style="-fx-text-fill: #10b981; -fx-font-size: 11; -fx-padding: 8; -fx-background-color: rgba(16, 185, 129, 0.1); -fx-border-color: #10b981; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <!-- Register Button -->
                <HBox spacing="8">
                    <Button text="Register Now" onAction="#onRegister" styleClass="btn-primary" style="-fx-padding: 10 20 10 20;" />
                </HBox>
            </children>
        </VBox>

        <!-- My Registrations Section -->
        <VBox styleClass="card" spacing="14" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14" />
            </padding>
            <children>
                <Label text="My Tournament Registrations" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #00BCD4;" />

                <!-- Search Field -->
                <VBox spacing="4">
                    <Label text="Search" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <TextField fx:id="searchField" promptText="Search by tournament or team name" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10; -fx-font-size: 12;" />
                    <Label text="Type to filter your registrations instantly" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Status Filter -->
                <VBox spacing="4">
                    <Label text="Filter by Status" style="-fx-text-fill: #cbd5e1; -fx-font-size: 12; -fx-font-weight: bold;" />
                    <ComboBox fx:id="myStatusFilter" promptText="All Statuses" style="-fx-control-inner-background: #0f1729; -fx-text-fill: #e0e7ff; -fx-padding: 10;" />
                    <Label text="Select a status to show only those registrations" style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" />
                </VBox>

                <!-- Registrations Table -->
                <TableView fx:id="myRegistrationsTable" prefHeight="200" VBox.vgrow="ALWAYS" styleClass="card">
                    <columns>
                        <TableColumn fx:id="tournamentCol" text="Tournament" prefWidth="200" />
                        <TableColumn fx:id="teamCol" text="Team Name" prefWidth="150" />
                        <TableColumn fx:id="dateCol" text="Registration Date" prefWidth="150" />
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="100" />
                    </columns>
                </TableView>

                <!-- Error Message -->
                <Label fx:id="cancelErrorLabel" text="" wrapText="true" style="-fx-text-fill: #ef4444; -fx-font-size: 11; -fx-padding: 8; -fx-background-color: rgba(239, 68, 68, 0.1); -fx-border-color: #ef4444; -fx-border-radius: 4; -fx-background-radius: 4;" />

                <!-- Cancel Button -->
                <HBox spacing="8">
                    <Button text="Cancel Registration" onAction="#onCancelRegistration" styleClass="btn-danger" style="-fx-padding: 10 20 10 20;" />
                    <Region HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Status Legend -->
                <HBox spacing="20" style="-fx-padding: 12; -fx-background-color: rgba(15, 23, 42, 0.8); -fx-border-radius: 6;">
                    <Label text="Legend:" style="-fx-text-fill: #00BCD4; -fx-font-weight: bold; -fx-font-size: 11;" />
                    <Label text="🟡 Pending - Waiting for admin review" style="-fx-text-fill: #fbbf24; -fx-font-size: 10;" />
                    <Label text="🟢 Confirmed - Registration approved" style="-fx-text-fill: #10b981; -fx-font-size: 10;" />
                    <Label text="🔴 Rejected - Registration declined" style="-fx-text-fill: #ef4444; -fx-font-size: 10;" />
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
