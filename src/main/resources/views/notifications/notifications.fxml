<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>

<VBox xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.notifications.NotificationsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Notifications" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <ComboBox fx:id="filterBox" prefWidth="180" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Mark as Read" onAction="#onMarkAsRead" />
                <Button text="Clear All" onAction="#onClearAll" styleClass="btn-danger" />
            </children>
        </HBox>
        <TableView fx:id="notificationsTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="typeCol" text="Type" prefWidth="110" />
                <TableColumn fx:id="messageCol" text="Message" prefWidth="520" />
                <TableColumn fx:id="timestampCol" text="Timestamp" prefWidth="180" />
                <TableColumn fx:id="readCol" text="Read" prefWidth="100" />
            </columns>
        </TableView>
    </children>
</VBox>


