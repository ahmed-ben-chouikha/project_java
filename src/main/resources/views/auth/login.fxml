<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.AuthController" styleClass="login-root">
    <children>
        <VBox spacing="14" maxWidth="420" styleClass="card">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
            <children>
                <Label text="RankUp" styleClass="brand-title" />
                <Label text="E-Sports Tournament Management Platform" styleClass="muted" />
                <TextField fx:id="emailField" promptText="Email" />
                <PasswordField fx:id="passwordField" promptText="Password" />
                <Button text="Sign In" onAction="#onSignIn" styleClass="btn-primary" />
                <Hyperlink text="Forgot Password" onAction="#onForgotPassword" />
                <Hyperlink text="Sign Up" onAction="#onSignUp" />
            </children>
        </VBox>
    </children>
</StackPane>

