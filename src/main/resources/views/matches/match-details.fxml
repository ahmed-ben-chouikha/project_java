<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.SimpleActionsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Falcons vs Nova" styleClass="page-title" />
        <Label text="2 - 1" styleClass="score-big" />
        <HBox spacing="20" styleClass="card"><padding><Insets top="12" right="12" bottom="12" left="12"/></padding><children>
            <Label text="Date: 2026-04-12 18:30"/><Label text="Location: Arena A"/><Label text="Tournament: Spring Cup"/><Label text="Status: Finished"/>
        </children></HBox>
        <TableView VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn text="Player" prefWidth="180" />
                <TableColumn text="KDA" prefWidth="140" />
                <TableColumn text="Points" prefWidth="110" />
                <TableColumn text="MVP" prefWidth="110" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button text="Edit Match" onAction="#onEdit" styleClass="btn-primary" />
                <Button text="Back to Matches" onAction="#goBackMatches" />
            </children>
        </HBox>
    </children>
</VBox>

