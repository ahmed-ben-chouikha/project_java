<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.SimpleActionsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Create / Edit Match" styleClass="page-title" />
        <GridPane hgap="10" vgap="10" styleClass="card">
            <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
            <children>
                <Label text="Team 1" GridPane.rowIndex="0" GridPane.columnIndex="0"/><ComboBox GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>
                <Label text="Team 2" GridPane.rowIndex="1" GridPane.columnIndex="0"/><ComboBox GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="220"/>
                <Label text="Match Date" GridPane.rowIndex="2" GridPane.columnIndex="0"/><DatePicker GridPane.rowIndex="2" GridPane.columnIndex="1" />
                <Label text="Match Time" GridPane.rowIndex="3" GridPane.columnIndex="0"/><TextField GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="HH:mm"/>
                <Label text="Status" GridPane.rowIndex="4" GridPane.columnIndex="0"/><ComboBox GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="220"/>
                <Label text="Tournament" GridPane.rowIndex="5" GridPane.columnIndex="0"/><ComboBox GridPane.rowIndex="5" GridPane.columnIndex="1" prefWidth="220"/>
                <Label text="Location" GridPane.rowIndex="6" GridPane.columnIndex="0"/><TextField GridPane.rowIndex="6" GridPane.columnIndex="1" promptText="Arena name"/>
                <Label text="Validation messages will appear here" styleClass="muted" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
            </children>
        </GridPane>
        <HBox spacing="8"><children><Button text="Save" onAction="#onSave" styleClass="btn-primary"/><Button text="Cancel" onAction="#goBackMatches"/></children></HBox>
    </children>
</VBox>

