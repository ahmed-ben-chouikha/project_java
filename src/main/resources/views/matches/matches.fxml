<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.matches.MatchesController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Matches" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search by team or date" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="statusFilter" prefWidth="160" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Create Match" onAction="#onCreateMatch" styleClass="btn-primary" />
            </children>
        </HBox>
        <TableView fx:id="matchesTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="team1Col" text="Team 1" prefWidth="170" />
                <TableColumn fx:id="scoreCol" text="Score" prefWidth="90" />
                <TableColumn fx:id="team2Col" text="Team 2" prefWidth="170" />
                <TableColumn fx:id="dateCol" text="Date" prefWidth="170" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button text="View" onAction="#onViewMatch" />
                <Button text="Edit" onAction="#onEditMatch" />
                <Button text="Delete" onAction="#onDeleteMatch" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" />
            </children>
        </HBox>
    </children>
</VBox>

