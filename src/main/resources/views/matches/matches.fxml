<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.matches.MatchesController" spacing="16" styleClass="page-root matches-page">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <VBox spacing="10" styleClass="card matches-hero">
            <children>
                <Label text="Matches" styleClass="page-title" />
                <Label text="Track live results, upcoming games, and finished match history in one sleek view." styleClass="muted" wrapText="true" />
                <HBox spacing="10" styleClass="matches-toolbar">
                    <children>
                        <TextField fx:id="searchField" promptText="Search by team or date" HBox.hgrow="ALWAYS" styleClass="matches-search" />
                        <ComboBox fx:id="statusFilter" prefWidth="160" styleClass="matches-filter" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="➕ New Match" onAction="#onCreateMatch" styleClass="btn-primary matches-create-btn" />
                    </children>
                </HBox>
            </children>
        </VBox>
            <columns>
                <TableColumn fx:id="team1Col" text="Team 1" prefWidth="170" />
                <TableColumn fx:id="scoreCol" text="Score" prefWidth="90" />
                <TableColumn fx:id="team2Col" text="Team 2" prefWidth="170" />
                <TableColumn fx:id="dateCol" text="Date" prefWidth="170" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
            </columns>
        </TableView>
        <HBox spacing="10" styleClass="matches-footer">
            <children>
                <Button text="View" onAction="#onViewMatch" styleClass="btn-secondary action-btn-view" />
                <Button text="Edit" onAction="#onEditMatch" styleClass="btn-secondary action-btn-edit" />
                <Button text="Delete" onAction="#onDeleteMatch" styleClass="btn-danger action-btn-delete" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="260" styleClass="matches-pagination" />
            </children>
        </HBox>
    </children>
</VBox>

