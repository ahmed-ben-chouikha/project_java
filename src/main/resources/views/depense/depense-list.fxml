<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.DepenseController">
    <top>
        <VBox style="-fx-padding: 15px; -fx-spacing: 10px; -fx-background-color: #f5f5f5;">
            <HBox spacing="10">
                <Label text="Expense Management" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Ajouter Dépense" onAction="#onAddDepense" style="-fx-padding: 8px 15px; -fx-font-size: 12px;"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Rechercher..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filterCombo" style="-fx-min-width: 150px;"/>
                <Button text="🔄 Rafraîchir" onAction="#onRefresh" style="-fx-padding: 5px 10px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="depenseTable" style="-fx-font-size: 11;">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="50"/>
                <TableColumn fx:id="titreColumn" text="Titre" prefWidth="150"/>
                <TableColumn fx:id="montantColumn" text="Montant (€)" prefWidth="100"/>
                <TableColumn fx:id="categorieColumn" text="Catégorie" prefWidth="100"/>
                <TableColumn fx:id="statutColumn" text="Statut" prefWidth="100"/>
                <TableColumn fx:id="teamNameColumn" text="Équipe" prefWidth="120"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox style="-fx-padding: 10px; -fx-background-color: #f5f5f5;" spacing="10">
            <Label text="© 2026 Expense Management System" style="-fx-text-fill: #666;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Chargé"/>
        </HBox>
    </bottom>
</BorderPane>

