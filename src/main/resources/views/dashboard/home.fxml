<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.dashboard.HomeController" spacing="14" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Welcome to RankUp Dashboard" styleClass="page-title" />

        <GridPane hgap="12" vgap="12">
            <children>
                <VBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="0"><children><Label text="27" styleClass="stat-value"/><Label text="Total matches this week"/></children></VBox>
                <VBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="1"><children><Label text="6" styleClass="stat-value"/><Label text="Upcoming tournaments"/></children></VBox>
                <VBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="2"><children><Label text="58" styleClass="stat-value"/><Label text="Team members"/></children></VBox>
                <VBox styleClass="stat-card" GridPane.rowIndex="0" GridPane.columnIndex="3"><children><Label text="14" styleClass="stat-value"/><Label text="Recent notifications"/></children></VBox>
            </children>
        </GridPane>

        <GridPane hgap="12" vgap="12">
            <children>
                <VBox spacing="8" styleClass="card" GridPane.rowIndex="0" GridPane.columnIndex="0">
                    <children><Label text="Recent Matches" styleClass="section-title"/><ListView fx:id="recentMatchesList" prefHeight="180"/></children>
                </VBox>
                <VBox spacing="8" styleClass="card" GridPane.rowIndex="0" GridPane.columnIndex="1">
                    <children><Label text="Upcoming Matches" styleClass="section-title"/><ListView fx:id="upcomingMatchesList" prefHeight="180"/></children>
                </VBox>
                <VBox spacing="8" styleClass="card" GridPane.rowIndex="0" GridPane.columnIndex="2">
                    <children><Label text="Announcements" styleClass="section-title"/><ListView fx:id="announcementsList" prefHeight="180"/></children>
                </VBox>
            </children>
        </GridPane>
    </children>
</VBox>

