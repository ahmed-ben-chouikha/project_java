<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.tournaments.TournamentRegistrationController" spacing="12" styleClass="page-root">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>
    <children>
        <Label text="Tournament Registrations" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search player or team" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="statusFilter" prefWidth="160" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Register" onAction="#onRegister" styleClass="btn-primary" />
            </children>
        </HBox>
        <TableView fx:id="registrationsTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="playerNameCol" text="Player Name" prefWidth="150" />
                <TableColumn fx:id="teamNameCol" text="Team Name" prefWidth="150" />
                <TableColumn fx:id="tournamentCol" text="Tournament" prefWidth="150" />
                <TableColumn fx:id="registrationDateCol" text="Registration Date" prefWidth="140" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="100" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button text="Edit Team Name" onAction="#onEditTeamName" />
                <Button text="View Status" onAction="#onViewStatus" />
                <Button text="Cancel Registration" onAction="#onCancelRegistration" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" />
            </children>
        </HBox>
    </children>
</VBox>
