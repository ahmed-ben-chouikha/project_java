<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.tournaments.TournamentsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Tournaments" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Search tournament" HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="statusFilter" prefWidth="160" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="➕ New Tournament" onAction="#onCreateTournament" styleClass="btn-primary" />
            </children>
        </HBox>
        <TableView fx:id="tournamentsTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="nameCol" text="Tournament Name" prefWidth="220" />
                <TableColumn fx:id="gameTypeCol" text="Game Type" prefWidth="150" />
                <TableColumn fx:id="startDateCol" text="Start Date" prefWidth="120" />
                <TableColumn fx:id="endDateCol" text="End Date" prefWidth="120" />
                <TableColumn fx:id="maxTeamsCol" text="Max Teams" prefWidth="100" />
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button text="👁️" onAction="#onViewTournament" />
                <Button text="✏️" onAction="#onEditTournament" />
                <Button text="🗑️" onAction="#onDeleteTournament" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
                <Pagination fx:id="pagination" prefWidth="220" />
            </children>
        </HBox>
    </children>
</VBox>

