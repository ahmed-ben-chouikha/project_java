<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.connexion3a36.rankup.controllers.SimpleActionsController" spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="RankUp Spring Cup" styleClass="page-title" />
        <Label text="2026-05-01 to 2026-05-10 | Tunis Arena | Prize Pool: $50,000" />

        <VBox styleClass="card" spacing="8"><padding><Insets top="12" right="12" bottom="12" left="12"/></padding><children>
            <Label text="Bracket / Standings (placeholder grid)" styleClass="section-title" />
            <Label text="Quarterfinals -> Semifinals -> Grand Final" />
        </children></VBox>

        <Label text="Tournament Matches" styleClass="section-title" />
        <TableView styleClass="card" prefHeight="170"><columns>
            <TableColumn text="Match" prefWidth="280" />
            <TableColumn text="Date" prefWidth="140" />
            <TableColumn text="Status" prefWidth="120" />
        </columns></TableView>

        <Label text="Participating Teams" styleClass="section-title" />
        <TableView styleClass="card" prefHeight="120"><columns>
            <TableColumn text="Team" prefWidth="220" />
            <TableColumn text="Country" prefWidth="140" />
        </columns></TableView>

        <Label text="Rewards: Gold / Silver / Bronze tiers" />
        <HBox spacing="8"><children><Button text="Edit Tournament" onAction="#onEdit" styleClass="btn-primary"/><Button text="Back" onAction="#goBackTournaments"/></children></HBox>
    </children>
</VBox>

