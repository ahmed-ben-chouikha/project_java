        <Button text="Tournaments" onAction="#goTournaments" styleClass="nav-btn" />
        <Button text="Budget" onAction="#goBudget" styleClass="nav-btn" />
        <Button text="Notifications" onAction="#goNotifications" styleClass="nav-btn" />
