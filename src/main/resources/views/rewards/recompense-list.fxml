<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.rankup.controllers.rewards.RecompenseController"
      spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Gestion des Récompenses" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Rechercher par nom ou description..." HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="typeFilter" prefWidth="150" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="createBtn" text="+ Ajouter" onAction="#onCreateRecompense" styleClass="btn-primary" />
                <Button fx:id="refreshBtn" text="🔄 Actualiser" onAction="#onRefresh" styleClass="btn-secondary" />
            </children>
        </HBox>
        <TableView fx:id="recompenseTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                <TableColumn fx:id="recompenseCol" text="Récompense" prefWidth="150" />
                <TableColumn fx:id="typeCol" text="Type" prefWidth="100" />
                <TableColumn fx:id="classementCol" text="Classement" prefWidth="100" />
                <TableColumn fx:id="descriptionCol" text="Description" prefWidth="250" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button fx:id="editBtn" text="✏️ Modifier" onAction="#onEditRecompense" styleClass="btn-secondary" />
                <Button fx:id="deleteBtn" text="🗑️ Supprimer" onAction="#onDeleteRecompense" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>

