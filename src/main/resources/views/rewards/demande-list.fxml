<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.rankup.controllers.rewards.DemandeRecompenseController"
      spacing="12" styleClass="page-root">
    <padding><Insets top="18" right="18" bottom="18" left="18"/></padding>
    <children>
        <Label text="Gestion des Demandes de Récompense" styleClass="page-title" />
        <HBox spacing="8">
            <children>
                <TextField fx:id="searchField" promptText="Rechercher par nom ou email..." HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="statutFilter" prefWidth="150" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="createBtn" text="+ Ajouter" onAction="#onCreateDemande" styleClass="btn-primary" />
                <Button fx:id="refreshBtn" text="🔄 Actualiser" onAction="#onRefresh" styleClass="btn-secondary" />
            </children>
        </HBox>
        <TableView fx:id="demandeTable" VBox.vgrow="ALWAYS" styleClass="card">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                <TableColumn fx:id="nomCol" text="Demandeur" prefWidth="150" />
                <TableColumn fx:id="emailCol" text="Email" prefWidth="180" />
                <TableColumn fx:id="motifCol" text="Motif" prefWidth="200" />
                <TableColumn fx:id="dateCol" text="Date" prefWidth="150" />
                <TableColumn fx:id="statutCol" text="Statut" prefWidth="120" />
            </columns>
        </TableView>
        <HBox spacing="8">
            <children>
                <Button fx:id="viewBtn" text="👁️ Voir" onAction="#onViewDemande" styleClass="btn-secondary" />
                <Button fx:id="editBtn" text="✏️ Modifier" onAction="#onEditDemande" styleClass="btn-secondary" />
                <Button fx:id="deleteBtn" text="🗑️ Supprimer" onAction="#onDeleteDemande" styleClass="btn-danger" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>

