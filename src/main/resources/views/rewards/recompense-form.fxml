<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.rankup.controllers.rewards.RecompenseFormController"
      spacing="12" styleClass="page-root" style="-fx-padding: 30;">
    <children>
        <Label fx:id="formTitle" text="Ajouter une nouvelle récompense" styleClass="page-title" />

        <VBox spacing="4" styleClass="form-section">
            <Label text="Nom de la récompense" styleClass="form-label" />
            <TextField fx:id="recompenseField" promptText="Ex: Trophée" styleClass="form-input" />
            <Label fx:id="recompenseError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <HBox spacing="20">
            <children>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Type" styleClass="form-label" />
                    <ComboBox fx:id="typeCombo" prefWidth="200" styleClass="form-input" />
                    <Label fx:id="typeError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Classement" styleClass="form-label" />
                    <TextField fx:id="classementField" promptText="1, 2, 3..." styleClass="form-input" />
                    <Label fx:id="classementError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
                </VBox>
            </children>
        </HBox>

        <VBox spacing="4">
            <Label text="Tournoi" styleClass="form-label" />
            <ComboBox fx:id="tournamentCombo" promptText="Sélectionner un tournoi" styleClass="form-input" />
            <Label fx:id="tournamentError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <VBox spacing="4" VBox.vgrow="ALWAYS">
            <Label text="Description" styleClass="form-label" />
            <TextArea fx:id="descriptionArea" promptText="Détails de la récompense..." wrapText="true"
                      styleClass="form-input" VBox.vgrow="ALWAYS" />
            <Label fx:id="descriptionError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <HBox spacing="8" style="-fx-padding: 20 0 0 0;">
            <children>
                <Button fx:id="saveBtn" text="💾 Enregistrer" onAction="#onSave" styleClass="btn-primary" />
                <Button fx:id="cancelBtn" text="❌ Annuler" onAction="#onCancel" styleClass="btn-secondary" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>

