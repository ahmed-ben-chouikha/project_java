<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.connexion3a36.rankup.controllers.rewards.DemandeFormController"
      spacing="12" styleClass="page-root" style="-fx-padding: 30;">
    <children>
        <Label fx:id="formTitle" text="Créer une nouvelle demande" styleClass="page-title" />

        <VBox spacing="4" styleClass="form-section">
            <Label text="Nom du demandeur" styleClass="form-label" />
            <TextField fx:id="nomField" promptText="Ex: Jean Dupont" styleClass="form-input" />
            <Label fx:id="nomError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <VBox spacing="4">
            <Label text="Email" styleClass="form-label" />
            <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="form-input" />
            <Label fx:id="emailError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <VBox spacing="4">
            <Label text="Recompense" styleClass="form-label" />
            <ComboBox fx:id="recompenseCombo" promptText="Selectionner une recompense" styleClass="form-input" />
            <Label fx:id="recompenseError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <VBox spacing="4" VBox.vgrow="ALWAYS">
            <Label text="Description de la demande" styleClass="form-label" />
            <TextArea fx:id="motifArea" promptText="Expliquez la raison de votre demande..." wrapText="true"
                      styleClass="form-input" VBox.vgrow="ALWAYS" />
            <Label fx:id="motifError" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" />
        </VBox>

        <HBox spacing="8" style="-fx-padding: 20 0 0 0;">
            <children>
                <Button fx:id="saveBtn" text="💾 Enregistrer" onAction="#onSave" styleClass="btn-primary" />
                <Button fx:id="cancelBtn" text="❌ Annuler" onAction="#onCancel" styleClass="btn-secondary" />
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>

